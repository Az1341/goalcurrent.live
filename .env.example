# GoalCurrent.live — copy to .env.local for local development.
# Never commit .env.local or real API keys.

# ── Required for live WC26 scores, events, lineups, and statistics ───────────
# Server-side only. Do NOT prefix with NEXT_PUBLIC_.
# Without this key the site still builds and runs using schedule metadata only.
API_FOOTBALL_KEY=

# ── Figma lineup board sync (scripts/sync-figma-final-lineups.mjs) ───────────
# Personal access token with file_content:read on the broadcast Figma file.
FIGMA_TOKEN=
# Optional — defaults to vV10C5mvxJ2wlb27PyxEt3 (WC final lineup board)
FIGMA_FILE_KEY=
# Optional api-sports fixture id override for the final (Match 104)
# Known: 53452537
API_FOOTBALL_FIXTURE_ID=
# Set NEXT_PUBLIC_VERIFY_MATCH=true to log Match 104 lineup verification in the browser
NEXT_PUBLIC_VERIFY_MATCH=
# Plugin bridge port (default 8765)
FIGMA_LINEUP_PLUGIN_PORT=8765

# ── Football-Data.org (optional secondary data source) ───────────────────────
FOOTBALL_DATA_KEY=

# ── ScoreBat Video API (optional WC26 top scorers tier-2 source) ─────────────
# Server-side only. Used when API-Football has no scorer rows.
SCOREBAT_API_TOKEN=

# ── API-Football dev simulation (local only — never set in production) ───────
# Values: off | 429 | 500 | timeout | empty
API_FOOTBALL_SIMULATE=off

# ── YouTube Data API v3 (video hub + category pages) ─────────────────────────
# Server-side only. Do NOT prefix with NEXT_PUBLIC_.
YOUTUBE_API_KEY=REPLACE_WITH_YOUR_KEY

# ── GNews API (secondary football news source) ───────────────────────────────
# Optional. Server-side only. Skipped when unset.
GNEWS_API_KEY=

# ── Daily content refresh cron ───────────────────────────────────────────────
# Required in production for /api/cron/refresh-content authorization.
CRON_SECRET=

# ── Debug routes (/api/debug/*) ──────────────────────────────────────────────
# Optional. Falls back to CRON_SECRET when unset.
DEBUG_SECRET=

# ── Upstash Redis (optional — cross-instance API rate limiting) ────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (production monitoring) ───────────────────────────────────────────
# Server-side DSN for API routes and SSR. Client uses NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional — source map upload during CI builds
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# NODE_ENV=development

# ── Firebase (Web Auth + FCM push) ───────────────────────────────────────────
# Client config from Firebase Console → Project settings → Your apps (Web).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Web Push certificates → Key pair (VAPID) in Cloud Messaging settings.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Server-only: full service account JSON (single line) for token verify + topic subscribe.
FIREBASE_SERVICE_ACCOUNT_JSON=
# ── GoalCurrent v2 (Supabase + intelligence briefs) ─────────────────────────
# Supabase project URL (same value for server and browser where noted).
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — brief generation (server-only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Editorial calendar timezone for "Today's Explanation" (IANA, default Europe/London)
GOALCURRENT_EDITORIAL_TIMEZONE=Europe/London

# Server-only HMAC secret for anonymous feedback identity hashing
GOALCURRENT_ANON_FEEDBACK_SECRET=

# Server-only secret for authorised match ingestion (scheduler / cron)
GOALCURRENT_INGESTION_SECRET=
