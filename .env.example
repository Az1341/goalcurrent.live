# GoalCurrent.online — copy to .env.local for local development.
# Never commit .env.local or real API keys.

# ── Required for live WC26 scores, events, lineups, and statistics ───────────
# Server-side only. Do NOT prefix with NEXT_PUBLIC_.
# Without this key the site still builds and runs using schedule metadata only.
API_FOOTBALL_KEY=

# ── ScoreBat Video API (optional WC26 top scorers tier-2 source) ─────────────
# Server-side only. Used when API-Football has no scorer rows.
SCOREBAT_API_TOKEN=

# ── API-Football dev simulation (local only — never set in production) ───────
# Values: off | 429 | 500 | timeout | empty
API_FOOTBALL_SIMULATE=off

# ── YouTube Data API v3 (video hub + category pages) ─────────────────────────
# Server-side only. Do NOT prefix with NEXT_PUBLIC_.
YOUTUBE_API_KEY=REPLACE_WITH_YOUR_KEY

# ── GNews API (secondary football news source) ───────────────────────────────
# Optional. Server-side only. Skipped when unset.
GNEWS_API_KEY=

# ── Daily content refresh cron ───────────────────────────────────────────────
# Required in production for /api/cron/refresh-content authorization.
CRON_SECRET=

# ── Sentry (production monitoring) ───────────────────────────────────────────
# Server-side DSN for API routes and SSR. Client uses NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional — source map upload during CI builds
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Google AdSense (client-safe — NEXT_PUBLIC_) ──────────────────────────────
# Publisher ID — defaults to ca-pub-8697460993506171 when unset.
NEXT_PUBLIC_ADSENSE_CLIENT=
# Display slot IDs — set in Vercel Production. Leave blank locally to skip ads.
NEXT_PUBLIC_ADSENSE_SLOT_HOME_MID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME_LOWER=
NEXT_PUBLIC_ADSENSE_SLOT_PL_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_PL_MID=
NEXT_PUBLIC_ADSENSE_SLOT_PL_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_WC26_MID=
NEXT_PUBLIC_ADSENSE_SLOT_LIVE_MID=
NEXT_PUBLIC_ADSENSE_SLOT_MATCH_MID=
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_MID=
# NODE_ENV=development
