  "scripts": {
    "sync:flags": "node scripts/sync-wc26-flags.mjs",
    "prebuild": "node scripts/sync-wc26-flags.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "i18n:check": "node scripts/check-message-parity.cjs",
